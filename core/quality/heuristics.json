{
  "name": "Heuristicas de Usabilidad",
  "version": "1.0",
  "based_on": "Nielsen 10 Heuristics — adaptado para web",
  "heuristics": [
    {"id":"H01","name":"Visibilidad del estado","checks":["Feedback en formularios","Confirmacion de acciones","Indicador de pagina activa","Progreso en procesos largos"]},
    {"id":"H02","name":"Correspondencia con el mundo real","checks":["Vocabulario apropiado para la audiencia","Iconos reconocibles","Orden logico de informacion"]},
    {"id":"H03","name":"Control y libertad","checks":["Boton volver o breadcrumbs","Modales se cierran con X/Escape/click fuera","Acciones destructivas piden confirmacion"]},
    {"id":"H04","name":"Consistencia y estandares","checks":["Botones primarios iguales en todo el sitio","Terminologia consistente","Navegacion uniforme"]},
    {"id":"H05","name":"Prevencion de errores","checks":["Campos con formato tienen mascara/ejemplo","Validacion en tiempo real","Opciones ambiguas tienen tooltip"]},
    {"id":"H06","name":"Reconocimiento antes que recuerdo","checks":["Labels siempre visibles","Navegacion muestra ubicacion actual","No se exige recordar info de paginas anteriores"]},
    {"id":"H07","name":"Flexibilidad y eficiencia","checks":["CTAs accesibles sin scroll excesivo","Formularios agrupan campos relacionados","Contenido prioritario above-the-fold"]},
    {"id":"H08","name":"Diseno estetico y minimalista","checks":["Sin elementos decorativos que compitan con el contenido","Jerarquia visual clara","Espacio en blanco suficiente"]},
    {"id":"H09","name":"Recuperacion ante errores","checks":["Errores dicen QUE salio mal","Sugieren COMO corregir","No destruyen datos ingresados","404 ofrece alternativas"]},
    {"id":"H10","name":"Ayuda y documentacion","checks":["Formularios complejos tienen instrucciones","Tooltips en funciones no evidentes","Contacto facil de encontrar","Estados vacios con instruccion"]}
  ],
  "scoring": {"PASS":"Cumple","PARTIAL":"Parcial — documentar","FAIL":"No cumple — documentar y sugerir","N/A":"No aplica"},
  "pass_criteria": "Ninguna en FAIL. Maximo 2 en PARTIAL."
}
